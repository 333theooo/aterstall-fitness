# Återställ — miljövariabler
# Kopiera till .env.local och fyll i. Utan dessa kör appen mot localStorage
# (lokal dev/demo) och premium kan aktiveras lokalt utan riktig betalning.

# --- Supabase (persistens, anonym auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (betalning) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pris-id från Stripe Dashboard (Products → Prices)
STRIPE_PRICE_MONTH=
STRIPE_PRICE_YEAR=
# Engångsprodukt "Återställningsprotokollet". Valfritt — utan id används
# ett inline-pris på 19 kr.
STRIPE_PRICE_PROTOKOLL=

# --- App ---
# Bas-URL för Checkout success/cancel-redirect (prod: din Vercel-domän)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
